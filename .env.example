# ── Active model ──────────────────────────────────────────────
# Set here to override models/config.yaml at runtime.
# Format: provider/model-name  (see README § Supported Models)
# MODEL=gemini/gemini-2.0-flash

# ── LLM API Keys — set the one matching your active provider ──
GOOGLE_API_KEY=your-google-api-key-here
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# MISTRAL_API_KEY=...

# ── OpenAI-compatible endpoint (optional) ─────────────────────
# Use any OpenAI-compatible API (KodeKloud, Together, Groq, etc.)
# OPENAI_COMPAT_API_KEY=sk-...
# OPENAI_COMPAT_BASE_URL=https://api.your-provider.com/v1

# ── Agentgateway (optional) ─────────────────────────────────────
# Uncomment to enable gateway mode.
# MCP_GATEWAY_URL=http://localhost:3000
# LLM_GATEWAY_URL=http://localhost:8080/v1
# LLM_GATEWAY_PROVIDER=openai   # openai | anthropic | google | openai-compat
# GATEWAY_API_KEY=              # optional: set if agentgateway requires auth
# LLM_GATEWAY_HOST_OVERRIDE=api.ai.kodekloud.com
# LLM_GATEWAY_MODEL=google/gemini-3-pro-preview

# ── MCP Server URLs ────────────────────────────────────────────
# Defaults shown — change only if you run servers on different ports
MCP_KUBERNETES_URL=http://localhost:3001/mcp
MCP_PROMETHEUS_URL=http://localhost:3002/mcp
MCP_ARGO_URL=http://localhost:3003/mcp

# ── Infrastructure endpoints ───────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
ARGOCD_URL=https://localhost:8443
ARGOCD_TOKEN=your-argocd-api-token-here

# ── SQLite backend (optional networked mode) ───────────────────
# Leave unset to use local ~/.sre_agent/memory.db (default).
# Set to the sqld Docker container URL for a networked SQLite server:
# SQLITE_URL=http://localhost:8082
# SQLITE_AUTH_TOKEN=


# JWT settings for agentgateway.yaml
JWT_ISSUER=https://YOUR-IDP-ISSUER
JWT_AUDIENCE=YOUR-API-OR-CLIENT-ID
JWT_JWKS_FILE=./tools/jwt/public.pem